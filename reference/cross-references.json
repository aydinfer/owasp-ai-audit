  "schema_version": 1,
  "note": "Hand-curated map from an OWASP AI Exchange slug to the MITRE ATLAS techniques/mitigations and NIST AI 100-2e2025 sections that describe the SAME threat phenomenon. OWASP stays the primary citation; these are additive secondary anchors for compliance and threat-intel audiences. A cross-reference is added only when the secondary source describes the same phenomenon — not merely the same vague theme.",
  "sources": {
    "owasp": "https://owaspai.org/",
    "atlas": {
      "site": "https://atlas.mitre.org/",
      "data": "https://raw.githubusercontent.com/mitre-atlas/atlas-data/main/dist/ATLAS.yaml",
      "id_verification": "atlas.mitre.org technique/mitigation pages are client-rendered and return HTTP 404 to non-browser clients (curl/CI), so a naive 200-check is meaningless — exactly the lesson the OWASP /go/ 302 redirects already taught this repo. Instead, snapshot-update.js verifies every cited ATLAS id exists in the authoritative atlas-data ATLAS.yaml dataset, which is a stronger guarantee than a rendered page."
    },
    "nist": {
      "pub": "https://csrc.nist.gov/pubs/ai/100/2/e2025/final",
      "section_note": "NIST refs name the taxonomy's attack-class section (e.g. 'Predictive AI — Evasion Attacks and Mitigations') and point at the publication landing page, which returns 200. Exact subsection numbers are not cited because they could not be machine-verified from the encrypted-CMap PDF in an offline build."
    }
  },
